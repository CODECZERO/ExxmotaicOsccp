# ─── Database ────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@localhost:5432/exxomatic

# ─── API Security ────────────────────────────────────────────────────
SECRET_KEY=your-secret-key
API_KEY=your-api-key

# ─── Logging ─────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ─── Network ─────────────────────────────────────────────────────────
BIND_HOST=0.0.0.0

# ─── Ports ───────────────────────────────────────────────────────────
CORE_PORT=5000
API_PORT=5050
ECHO_PORT=8000
ECHO_N_PORT=5001

# ─── OCPP Behaviour ─────────────────────────────────────────────────
HEARTBEAT_INTERVAL_S=10

# ─── Charger Defaults (TKT EV catalog) ──────────────────────────────
CHARGER_DEFAULT_VENDOR=TKT
CHARGER_DEFAULT_MODEL=DC-60kW

# ─── SSL / Let's Encrypt (required for Cloudflare Full Strict) ──────
# Your domain (must be managed via Cloudflare DNS)
DOMAIN_NAME=exxomatic.therisewebd.in

# Email for Let's Encrypt certificate notifications
LETSENCRYPT_EMAIL=admin@example.com

# Cloudflare API Token with Zone:DNS:Edit permission
# Create at: https://dash.cloudflare.com/profile/api-tokens
# Use the "Edit zone DNS" template for your domain
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
